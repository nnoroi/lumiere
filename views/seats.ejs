<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Select Seats - <%= movie.title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="seats-page text-white">
  <div class="container my-5">
    <div class="row justify-content-center">
      <div class="col-lg-9 col-md-10 text-center">

        <a href="/booking?movieId=<%= movie.id %>" class="seat-back-link">
          <i class="fa fa-arrow-left"></i> Back to showtimes
        </a>

        <h1 class="h2 mb-1"><%= movie.title %></h1>
        <p class="text-muted mb-4">
          <i class="fa fa-calendar"></i> <%= showtime.date %> &nbsp;|&nbsp;
          <i class="fa fa-clock"></i> <%= showtime.time %>
        </p>

        <div class="seat-screen"></div>
        <div class="seat-screen-label"><%= screenName %> &middot; <%= screenType %></div>

        <div class="seat-legend">
          <span class="seat-legend-swatch"><span class="seat-legend-dot is-available"></span> Available</span>
          <span class="seat-legend-swatch"><span class="seat-legend-dot is-selected"></span> Selected</span>
          <span class="seat-legend-swatch"><span class="seat-legend-dot is-occupied"></span> Taken</span>
        </div>

        <form action="/checkout" method="POST">
          <input type="hidden" name="movieId" value="<%= movie.id %>">
          <input type="hidden" name="showingId" value="<%= showtime.showingId %>">

          <% seatLayout.forEach(row => { %>
            <div class="seat-row">
              <span class="seat-row-letter"><%= row.letter %></span>
              
              <div class="seat-row-half is-left">
                <% row.left.forEach(seat => { %>
                  <input type="checkbox" name="selectedSeats" value="<%= seat.id %>" id="seat-<%= seat.id %>"
                    class="seat-checkbox" <%= seat.isOccupied ? 'disabled' : '' %> data-name="<%= seat.name %>">
                  <label for="seat-<%= seat.id %>" class="seat-label"
                    aria-label="Seat <%= seat.name %><%= seat.isOccupied ? ', unavailable' : ', available' %>">
                    <%= seat.num %>
                  </label>
                <% }); %>
              </div>
              
              <span></span> <div class="seat-row-half">
                <% row.right.forEach(seat => { %>
                  <input type="checkbox" name="selectedSeats" value="<%= seat.id %>" id="seat-<%= seat.id %>"
                    class="seat-checkbox" <%= seat.isOccupied ? 'disabled' : '' %> data-name="<%= seat.name %>">
                  <label for="seat-<%= seat.id %>" class="seat-label"
                    aria-label="Seat <%= seat.name %><%= seat.isOccupied ? ', unavailable' : ', available' %>">
                    <%= seat.num %>
                  </label>
                <% }); %>
              </div>
              
              <span class="seat-row-letter"><%= row.letter %></span>
            </div>
          <% }); %>

          <div class="seat-bar">
            <div class="seat-bar-info">
              <span id="seat-count" class="seat-bar-count">0 / 6 seats selected</span>
              <span id="seat-chips" class="seat-bar-chips"></span>
            </div>
            <span id="seat-warning" class="seat-bar-warning"></span>
            <button type="submit" id="submit-btn" class="btn btn-lumiere btn-lg" disabled>Select seats to continue</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="/js/seats.js"></script>
</body>
</html>