<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel — Lumiere Cinema</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-page text-white">
  <div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 fw-bold mb-0"><i class="fa-solid fa-film me-2"></i>Admin Panel</h1>
      <a href="/logout" class="btn btn-outline-secondary btn-sm">Logout</a>
    </div>

    <% if (success) { %>
      <div class="alert alert-success"><i class="fa fa-circle-check me-2"></i><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-danger"><i class="fa fa-circle-xmark me-2"></i><%= error %></div>
    <% } %>

    <div class="admin-card p-4">
      <h5 class="fw-bold mb-4">Add New Movie & Showing</h5>
      <form action="/admin/add-movie" method="POST">

        <p class="admin-section-title">Movie Details</p>
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <label class="form-label">Title</label>
            <input type="text" class="form-control admin-input" name="title" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Poster URL</label>
            <input type="url" class="form-control admin-input" name="poster" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Genre</label>
            <select class="form-select admin-input" name="genre" required>
              <option value="" disabled selected>Select</option>
              <option>Action</option>
              <option>Animation</option>
              <option>Comedy</option>
              <option>Documentary</option>
              <option>Drama</option>
              <option>Fantasy</option>
              <option>Horror</option>
              <option>Romance</option>
              <option>Sci-Fi</option>
              <option>Thriller</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label">Duration (mins)</label>
            <input type="number" class="form-control admin-input" name="duration" min="1" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Rating</label>
            <select class="form-select admin-input" name="rating" required>
              <option value="" disabled selected>Select</option>
              <option>U</option>
              <option>PG</option>
              <option>12A</option>
              <option>15</option>
              <option>18</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">Director</label>
            <input type="text" class="form-control admin-input" name="director" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Cast (comma-separated)</label>
            <input type="text" class="form-control admin-input" name="cast" placeholder="Tom Hardy, Cillian Murphy" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Country</label>
            <input type="text" class="form-control admin-input" name="country" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Trailer URL (YouTube)</label>
            <input type="url" class="form-control admin-input" name="trailer" placeholder="https://www.youtube.com/watch?v=..." required>
          </div>
          <div class="col-12">
            <label class="form-label">Description</label>
            <textarea class="form-control admin-input" name="description" rows="3" required></textarea>
          </div>
        </div>

        <p class="admin-section-title">Showing Details</p>
        <div class="row g-3 mb-4">
          <div class="col-md-4">
            <label class="form-label">Screen Name</label>
            <input type="text" class="form-control admin-input" name="screenName" placeholder="e.g. Big Room 1" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Screen Type</label>
            <select class="form-select admin-input" name="screenType" required>
              <option value="" disabled selected>Select</option>
              <option value="Standard">Standard</option>
              <option value="3D">3D</option>
              <option value="IMAX">IMAX</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label">Date</label>
            <input type="date" class="form-control admin-input" name="date" required>
          </div>
          <div class="col-md-2">
            <label class="form-label">Time</label>
            <input type="time" class="form-control admin-input" name="time" required>
          </div>
        </div>

        <p class="admin-section-title">Seat Layout</p>
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <label class="form-label">Number of Rows (max 26)</label>
            <input type="number" class="form-control admin-input" name="numRows" value="5" min="1" max="26" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Seats per Row (max 20)</label>
            <input type="number" class="form-control admin-input" name="seatsPerRow" value="6" min="1" max="20" required>
          </div>
        </div>

        <button type="submit" class="btn btn-lumiere btn-lg w-100">
          <i class="fa fa-plus me-2"></i> Add Movie & Showing
        </button>

      </form>
    </div>
  </div>
</body>
</html>