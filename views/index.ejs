<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lumiere Cinema</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <link rel="stylesheet" href="/css/style1.css">
    <link rel="stylesheet" href="/css/footer.css">
</head>
<body>

    <nav class="navbar mb-4">
    <div class="navbar-container">
        <a class="navbar-brand" href="/">LUMIERE</a>
        
        <div class="search">
            <form id="searchForm">
                <input 
                    type="text" 
                    id="searchInput"
                    placeholder="Search Movies" 
                    aria-label="Search">
                <button type="submit">
                    <i class="fa fa-search"></i>
                </button>
            </form>
        </div>
    </div>
</nav>

    <div class="container">
        <h1 class="mb-4">Now Showing</h1>
        
        <div id="movie-container" class="row g-4">
            <% movies.forEach(movie => { %>
                <div class="col-md-4">
                    <div class="card h-100">
                        <img src="<%= movie.poster %>" class="card-img-top" alt="<%= movie.title %> poster">
                        <div class="card-body">
                            <h5 class="card-title fw-bold"><%= movie.title %></h5>
                            <p class="card-text mb-1"><strong>Genre:</strong> <%= movie.genre %></p>
                            <p class="card-text mb-1"><strong>Duration:</strong> <%= movie.duration %> min</p>
                            <span class="movie-rating"><%= movie.rating %></span>
                        </div>
                        <div class="card-footer border-0 bg-transparent">
                            <a href="/booking?movieId=<%= movie.id %>" class="btn btn-lumiere w-100">Book Tickets</a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>

    <div class="footer">
        <div class="col-1">
            <h3>Links</h3>
            <a href="/">Movies</a>
        </div>
        <div class="col-2">
            <h3>Newsletter</h3>
            <form>
                <input type="email" placeholder="Your Email Address" required>
                <br>
                <button type="submit">SUBSCRIBE NOW</button>
            </form>
        </div>
        <div class="col-3">
            <h3>Contact</h3>
            <p>123, XYZ Road, BSK 3<br> Birmingham</p>
            <div class="social-icons">
                <i class="fa-brands fa-tiktok"></i>
                <i class="fa-brands fa-instagram"></i>
                <i class="fa-brands fa-facebook"></i>
            </div>
        </div>
    </div>

    <script src="/app.js"></script>
</body>
</html>