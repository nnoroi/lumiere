<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lumiere Cinema</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/footer.css">
</head>
<body>

    <nav class="navbar mb-4">
        <div class="navbar-container">
            <a class="navbar-brand" href="/">LUMIERE</a>
            <div class="nav-actions">
                <div class="search">
                    <form id="searchForm">
                        <input 
                            type="text" 
                            id="searchInput"
                            placeholder="Search Movies" 
                            aria-label="Search">
                        <button type="submit">
                            <i class="fa fa-search"></i>
                        </button>
                    </form>
                </div>
                <div class="account">
                    <a href="/account" aria-label="Account">
                        <i class="fa fa-user"></i>
                    </a>
                </div>
            </div>
        </div>
    </nav>
   <div class="filter-wrapper container mb-4">
    <form action="/" method="GET" class="row g-2 align-items-end bg-dark p-3 rounded">
        
        <div class="col-md-3">
            <label for="genre" class="text-white small mb-1">Genre</label>
            <select name="genre" id="genre" class="form-select bg-secondary text-white border-0">
                <option value="">All Genres</option>
                <option value="Sci-Fi" <%= selectedGenre === 'Sci-Fi' ? 'selected' : '' %>>Sci-Fi</option>
                <option value="Animation" <%= selectedGenre === 'Animation' ? 'selected' : '' %>>Animation</option>
                <option value="Drama" <%= selectedGenre === 'Drama' ? 'selected' : '' %>>Drama</option>
                <option value="Comedy" <%= selectedGenre === 'Comedy' ? 'selected' : '' %>>Comedy</option>
                <option value="Action" <%= selectedGenre === 'Action' ? 'selected' : '' %>>Action</option>
                <option value="Thriller" <%= selectedGenre === 'Thriller' ? 'selected' : '' %>>Thriller</option>
                <option value="Crime" <%= selectedGenre === 'Crime' ? 'selected' : '' %>>Crime</option>
                <option value="Historical" <%= selectedGenre === 'Historical' ? 'selected' : '' %>>Historical</option>
                <option value="Musical" <%= selectedGenre === 'Musical' ? 'selected' : '' %>>Musical</option>
                <option value="Adventure" <%= selectedGenre === 'Adventure' ? 'selected' : '' %>>Adventure</option>
                <option value="Romance" <%= selectedGenre === 'Romance' ? 'selected' : '' %>>Romance</option>
            </select>
        </div>

        <div class="col-md-3">
            <label for="rating" class="text-white small mb-1">Age Rating</label>
            <select name="rating" id="rating" class="form-select bg-secondary text-white border-0">
                <option value="">All Ratings</option>
                <option value="U" <%= selectedRating === 'U' ? 'selected' : '' %>>U</option>
                <option value="PG" <%= selectedRating === 'PG' ? 'selected' : '' %>>PG</option>
                <option value="12A" <%= selectedRating === '12A' ? 'selected' : '' %>>12A</option>
                <option value="15" <%= selectedRating === '15' ? 'selected' : '' %>>15</option>
                <option value="18" <%= selectedRating === '18' ? 'selected' : '' %>>18</option>
            </select>
        </div>

        <div class="col-md-3">
            <label for="sortByTime" class="text-white small mb-1">Showtime Schedule</label>
            <select name="sortByTime" id="sortByDate" class="form-select bg-secondary text-white border-0">
                <option value="">Default View</option>
                <option>Recent</option>
                <option></option>
            </select>
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-danger w-100" style="background-color: #D13704; border: none;">Apply Filters</button>
            <a href="/" class="btn btn-outline-light w-100">Reset</a>
        </div>
    </form>
</div>


    <div class="container">
        <h1 class="mb-4">Now Showing</h1>
        
        <div id="movie-container" class="row g-4">
            <% movies.forEach(movie => { %>
                <div class="col-md-4">
                    <div class="card h-100">
                        <img src="<%= movie.poster %>" class="card-img-top" alt="<%= movie.title %> poster">
                        <div class="card-body">
                            <h5 class="card-title fw-bold"><%= movie.title %></h5>
                            <p class="card-text mb-1"><strong>Genre:</strong> <%= movie.genre %></p>
                            <p class="card-text mb-1"><strong>Duration:</strong> <%= movie.duration %> min</p>
                            <span class="movie-rating"><%= movie.rating %></span>
                        </div>
                        <div class="card-footer border-0 bg-transparent">
                            <a href="/booking?movieId=<%= movie.id %>" class="btn btn-lumiere w-100">Book Tickets</a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>

    <div class="footer">
        <div class="col-1">
            <h3>Links</h3>
            <a href="/">Movies</a>
        </div>
        <div class="col-2">
            <h3>Newsletter</h3>
            <form>
                <input type="email" placeholder="Your Email Address" required>
                <br>
                <button type="submit">SUBSCRIBE NOW</button>
            </form>
        </div>
        <div class="col-3">
            <h3>Contact</h3>
            <p>123, XYZ Road, BSK 3<br> Birmingham</p>
            <div class="social-icons">
                <i class="fa-brands fa-tiktok"></i>
                <i class="fa-brands fa-instagram"></i>
                <i class="fa-brands fa-facebook"></i>
            </div>
        </div>
    </div>
</body>
</html>