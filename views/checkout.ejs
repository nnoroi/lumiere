<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - Lumiere Cinema</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/checkout.css">
</head>
<body class="checkout-page text-white">

    <div class="container my-5">
        <div class="card checkout-card text-white p-4 mx-auto shadow">
            <h2 class="mb-4 checkout-title fw-bold"><i class="fa-solid fa-credit-card me-2"></i>Checkout Summary</h2>
            
            <div class="summary-box mb-4">
                <h5 class="fw-bold mb-2 text-white"><%= movie.title %></h5>
                <p class="mb-1 small text-white-50"><strong>Showtime:</strong> <%= time %></p>
                <p class="mb-0 small text-white-50"><strong>Selected Seats:</strong> <%= seats %></p>
            </div>

            <!-- START OF NEW PRICE BREAKDOWN BOX -->
            <div class="p-3 rounded mb-4" style="background-color: #15151C; border: 1px solid #2A2A35;">
                <h6 class="fw-bold text-white mb-3"><i class="fa-solid fa-receipt me-2 text-danger"></i>Price Breakdown</h6>
                <div class="d-flex justify-content-between small text-white-50 mb-2">
                    <span>Ticket Price (<%= tickets %> x)</span>
                    <span><%= currency %> <%= unitPrice %></span>
                </div>
                <hr class="border-secondary my-2">
                <div class="d-flex justify-content-between fw-bold text-white fs-5">
                    <span>Total Amount:</span>
                    <span style="color: #E50914;"><%= currency %> <%= totalPrice %></span>
                </div>
            </div>
            <!-- END OF NEW PRICE BREAKDOWN BOX -->

            <form action="/confirm-booking" method="POST">
                <input type="hidden" name="movieTitle" value="<%= movie.title %>">
                <input type="hidden" name="showTime" value="<%= time %>">
                <input type="hidden" name="selectedSeats" value="<%= seats %>">
                <input type="hidden" name="tickets" value="<%= tickets %>">
                <!-- Sending prices forward to your final confirmation route safely -->
                <input type="hidden" name="totalPrice" value="<%= totalPrice %>">
                <input type="hidden" name="currency" value="<%= currency %>">

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" name="name" required placeholder="Enter your full name">
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" name="email" required placeholder="name@example.com">
                </div>

                <div class="mb-3">
                    <label class="form-label">Tickets</label>
                    <input type="text" class="form-control text-white-50" value="<%= tickets %> Ticket(s)" readonly>
                </div>

                <hr class="border-secondary my-4">

                <h5 class="fw-bold mb-3 text-white"><i class="fa-solid fa-wallet me-2"></i>Select Payment Method</h5>
                
                <div class="d-flex gap-3 mb-4">
                    <div class="form-check p-3 rounded flex-fill text-center option-box" id="cardBox" style="cursor: pointer;">
                        <input class="form-check-input d-none" type="radio" name="paymentMethod" id="cardPay" value="Credit/Debit Card" checked>
                        <label class="form-check-label w-100 fw-bold text-white" for="cardPay" style="cursor: pointer;">
                            <i class="fa-solid fa-card-membership me-2 text-danger"></i>Card
                        </label>
                    </div>
                    <div class="form-check p-3 rounded flex-fill text-center option-box" id="paypalBox" style="cursor: pointer;">
                        <input class="form-check-input d-none" type="radio" name="paymentMethod" id="paypalPay" value="PayPal">
                        <label class="form-check-label w-100 fw-bold text-white" for="paypalPay" style="cursor: pointer;">
                            <i class="fa-brands fa-paypal me-2 text-info"></i>PayPal
                        </label>
                    </div>
                </div>

                <div id="paymentInputsContainer" class="p-3 rounded mb-4" style="background-color: #0F0F14; border: 1px dashed #2A2A35;">
                    
                    <div id="cardFields">
                        <div class="mb-3">
                            <label class="form-label small text-white-50">Card Number</label>
                            <input type="text" class="form-control card-mask" placeholder="1234 5678 1234 5678">
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <label class="form-label small text-white-50">Expiry</label>
                                <input type="text" class="form-control" placeholder="MM/YY">
                            </div>
                            <div class="col-6">
                                <label class="form-label small text-white-50">CVV</label>
                                <input type="password" class="form-control" placeholder="***" maxlength="3">
                            </div>
                        </div>
                    </div>

                    <div id="paypalFields" class="d-none text-center py-2">
                        <p class="small text-white-50 mb-2">You will be securely redirected to PayPal to verify account login credentials.</p>
                        <span class="badge bg-info text-dark p-2 fs-6"><i class="fa-brands fa-paypal me-1"></i> Sandbox Test Mode Active</span>
                    </div>
                </div>

                <button type="submit" class="btn btn-checkout w-100 py-2 fs-5">
                    Confirm & Purchase (<%= currency %> <%= totalPrice %>)
                </button>
            </form>
        </div>
    </div>

    <script src="/js/checkout.js"></script>
</body>
</html>