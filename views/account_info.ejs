<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Account - Lumiere Cinema</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/account_info.css">
</head>
<body class= "text-white">

    <nav class="navbar mb-4">
        <div class="navbar-container">
            <a class="navbar-brand" href="/">LUMIERE</a>
            <div class="nav-actions">
                <div class="search">
                    <form id="searchForm">
                        <input 
                            type="text" 
                            id="searchInput"
                            placeholder="Search Movies" 
                            aria-label="Search">
                        <button type="submit">
                            <i class="fa fa-search"></i>
                        </button>
                    </form>
                </div>
                <div class="account">
                    <a href="/account" aria-label="Account">
                        <i class="fa fa-user"></i>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <div class="d-flex justify-content-between align-items-center border-bottom border-secondary pb-3 mb-4">
            <div>
                <h1 class="fw-bold">My Dashboard</h1>
                <p class="text-muted m-0">Logged in as: <strong class="text-white"><%= email %></strong></p>
            </div>
            <div>
                <a href="/" class="btn btn-outline-light me-2">Back to Movies</a>
                <a href="/logout" class="btn btn-danger">Log Out</a>
            </div>
        </div>

        <h2 class="h4 mb-3 text-danger"><i class="fa fa-history me-2"></i>Booking History</h2>

        <% if (bookings.length > 0) { %>
            <div class="row g-3">
                <% bookings.forEach(booking => { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card bg-secondary text-white border-0 h-100 shadow">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h5 class="card-title fw-bold m-0"><%= booking.movieTitle %></h5>
                                    <span class="badge bg-danger"><%= booking.bookingReference %></span>
                                </div>
                                <hr class="border-light opacity-20 my-2">
                                <p class="card-text mb-1"><i class="fa fa-user me-2"></i><strong>Name:</strong> <%= booking.name %></p>
                                <p class="card-text mb-1"><i class="fa fa-clock me-2"></i><strong>Time:</strong> <%= booking.showTime %></p>
                                <p class="card-text mb-1"><i class="fa fa-chair me-2"></i><strong>Seats:</strong> <%= booking.selectedSeats %></p>
                                <p class="card-text mb-0"><i class="fa fa-ticket me-2"></i><strong>Tickets:</strong> <%= booking.tickets %></p>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="p-5 text-center bg-black bg-opacity-20 rounded border border-secondary">
                <i class="fa fa-ticket-alt fa-3x text-muted mb-3"></i>
                <p class="text-muted">You haven't made any cinema bookings yet.</p>
                <a href="/" class="btn btn-sm btn-danger btn-book-now">Book a Movie Now</a>
            </div>
        <% } %>
    </div>

    <div class="footer">
        <div class="col-1">
            <h3>Links</h3>
            <a href="/">Movies</a>
        </div>
        <div class="col-2">
            <h3>Newsletter</h3>
            <form>
                <input type="email" placeholder="Your Email Address" required>
                <br>
                <button type="submit">SUBSCRIBE NOW</button>
            </form>
        </div>
        <div class="col-3">
            <h3>Contact</h3>
            <p>123, XYZ Road, BSK 3<br> Birmingham</p>
            <div class="social-icons">
                <i class="fa-brands fa-tiktok"></i>
                <i class="fa-brands fa-instagram"></i>
                <i class="fa-brands fa-facebook"></i>
            </div>
        </div>
    </div>

</body>
</html>