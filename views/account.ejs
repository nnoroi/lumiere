<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lumiere Cinema - Account</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/reg_form.css">
</head>
<body>

    <nav class="navbar mb-4">
        <div class="navbar-container">
            <a class="navbar-brand" href="/">LUMIERE</a>
            <div class="nav-actions">
                <div class="search">
                    <form id="searchForm">
                        <input 
                            type="text" 
                            id="searchInput"
                            placeholder="Search Movies" 
                            aria-label="Search">
                        <button type="submit">
                            <i class="fa fa-search"></i>
                        </button>
                    </form>
                </div>
                <div class="account">
                    <a href="/account" aria-label="Account">
                        <i class="fa fa-user"></i>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="form-wrapper">
        <div class="form-container">
            
            <% if (mode === 'signup') { %>
                <h2>Create Account</h2>
                <p class="form-subtitle">Join Lumiere Cinema today</p>

                <form action="/register" method="POST" id="authForm">
                    <div class="input-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" placeholder="Enter your email" name="email" required>
                    </div>
            <% } else { %>
                <h2>Sign In</h2>
                <p class="form-subtitle">Welcome back to Lumiere Cinema</p>

                <form action="/login" method="POST" id="authForm">
            <% } %>

                <div class="input-group">
                    <label for="uname">Username</label>
                    <input type="text" id="uname" placeholder="Enter Username" name="username" required>
                </div>

                <div class="input-group">
                    <label for="psw">Password</label>
                    <input type="password" id="psw" placeholder="Enter Password" name="password" required>
                </div>

                <% if (mode === 'login') { %>
                    <div class="form-actions-row">
                        <label class="remember-me">
                            <input type="checkbox" checked="checked" name="remember"> Remember me
                        </label>
                        <span class="forgot-psw">Forgot <a href="#">password?</a></span>
                    </div>
                <% } %>

                <button type="submit" class="btn-submit">
                    <%= mode === 'signup' ? 'Register' : 'Login' %>
                </button>
            </form>

            <div class="form-toggle-footer">
                <br>
                <p>
                    <% if (mode === 'signup') { %>
                        Already have an account? <a href="/account?mode=login" id="switch-mode">Sign In</a>
                    <% } else { %>
                        Don't have an account? <a href="/account?mode=signup" id="switch-mode">Sign Up</a>
                    <% } %>
                </p>
            </div>
        </div>
    </div>

    <div class="footer">
        <div class="col-1">
            <h3>Links</h3>
            <a href="/">Movies</a>
        </div>
        <div class="col-2">
            <h3>Newsletter</h3>
            <form>
                <input type="email" placeholder="Your Email Address" required>
                <br>
                <button type="submit">SUBSCRIBE NOW</button>
            </form>
        </div>
        <div class="col-3">
            <h3>Contact</h3>
            <p>123, XYZ Road, BSK 3<br> Birmingham</p>
            <div class="social-icons">
                <i class="fa-brands fa-tiktok"></i>
                <i class="fa-brands fa-instagram"></i>
                <i class="fa-brands fa-facebook"></i>
            </div>
        </div>
    </div>

    <script src="/app.js"></script>
</body>
</html>